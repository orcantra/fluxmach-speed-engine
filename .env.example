# Fluxmach Speed Engine - Environment Variables Template
# Copy this file to .env and fill in the values

# Server Port (default :8080)
# PORT=:8080

# Server Information
SERVER_NAME="Fluxmach Edge Node 1"
LOCATION="New York, US"

# API Security Key (Required)
# Use a long random string for production
FLUXMACH_AUTH_KEY=long-random-secret
